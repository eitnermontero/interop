<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE configuration>

<configuration scan="true">
  <conversionRule conversionWord="crlf" converterClass="bo.com.sintesis.mdqr.auth.config.CRLFLogConverter"/>
  <property name="CONSOLE_LOG_PATTERN" value="${CONSOLE_LOG_PATTERN:-%clr(%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX}){faint} %clr(%5p) %clr(${PID:- }){magenta} %clr(---){faint} [%clr(%15.15t){faint}] %clr(%-40.40logger{39}){cyan} %clr(:){faint} %clr([traceId=%X{traceId:-} spanId=%X{spanId:-} reqId=%X{requestId:-} clientIp=%X{clientIp:-}]){yellow} %crlf(%msg){red} %n${LOG_EXCEPTION_CONVERSION_WORD:-%xEx}}"/>
  <property name="LOG_DIR" value="${LOG_DIR:-${LOG_PATH:-logs}}"/>
  <property name="LOG_FILE" value="${LOG_FILE:-admin-service.log}"/>

  <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
  <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

  <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>${LOG_DIR}/${LOG_FILE}</file>
    <encoder class="net.logstash.logback.encoder.LogstashEncoder">
      <includeMdc>true</includeMdc>
      <includeContext>false</includeContext>
      <fieldNames>
        <timestamp>@timestamp</timestamp>
        <message>message</message>
        <thread>thread</thread>
        <logger>logger</logger>
        <level>level</level>
        <levelValue>[ignore]</levelValue>
        <version>[ignore]</version>
      </fieldNames>
    </encoder>
    <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
      <fileNamePattern>${LOG_DIR}/${LOG_FILE}.%d{yyyy-MM-dd}.%i.gz</fileNamePattern>
      <maxFileSize>${LOG_MAX_FILE_SIZE:-1GB}</maxFileSize>
      <maxHistory>${LOG_MAX_HISTORY:-180}</maxHistory>
      <totalSizeCap>${LOG_TOTAL_SIZE_CAP:-50GB}</totalSizeCap>
    </rollingPolicy>
  </appender>

  <appender name="ASYNC_FILE" class="ch.qos.logback.classic.AsyncAppender">
    <queueSize>2048</queueSize>
    <discardingThreshold>0</discardingThreshold>
    <includeCallerData>false</includeCallerData>
    <appender-ref ref="FILE"/>
  </appender>

  <!-- Application -->
  <logger name="bo.com.sintesis.mdqr" level="INFO"/>

  <!-- Spring -->
  <logger name="org.springframework" level="WARN"/>
  <logger name="org.springframework.boot.autoconfigure.logging" level="INFO"/>

  <!-- Spring Cloud -->
  <logger name="org.springframework.cloud.vault" level="WARN"/>
  <logger name="org.springframework.vault" level="WARN"/>
  <logger name="org.springframework.cloud.consul" level="WARN"/>
  <!-- Polls de Consul cuando esta caido inundan log con stacktraces cada N segundos. -->
  <logger name="org.springframework.cloud.consul.discovery.ConsulCatalogWatch" level="OFF"/>
  <logger name="org.springframework.cloud.consul.discovery.reactive.ConsulReactiveDiscoveryClient" level="OFF"/>
  <logger name="org.springframework.cloud.consul.discovery.ConsulDiscoveryClient" level="OFF"/>
  <logger name="org.springframework.cloud.consul.config.ConfigWatch" level="OFF"/>
  <logger name="org.springframework.cloud.consul.ConsulHealthIndicator" level="OFF"/>
  <logger name="org.springframework.cloud.client.discovery.health.DiscoveryClientHealthIndicator" level="OFF"/>
  <logger name="org.springframework.scheduling.support.TaskUtils$LoggingErrorHandler" level="OFF"/>
  <logger name="org.springframework.cloud.loadbalancer" level="WARN"/>
  <logger name="org.springframework.cloud.context" level="WARN"/>
  <logger name="org.springframework.cloud.bootstrap" level="INFO"/>

  <!-- Spring Data -->
  <logger name="org.springframework.data.repository.config" level="WARN"/>

  <!-- Security -->
  <logger name="org.springframework.security" level="WARN"/>

  <!-- Keycloak admin client -->
  <logger name="org.keycloak.admin.client" level="INFO"/>

  <!-- Hibernate -->
  <logger name="org.hibernate" level="WARN"/>
  <logger name="org.hibernate.orm.deprecation" level="ERROR"/>

  <!-- Database -->
  <logger name="com.zaxxer" level="WARN"/>
  <logger name="org.postgresql" level="WARN"/>
  <logger name="liquibase" level="WARN"/>
  <logger name="LiquibaseSchemaResolver" level="INFO"/>

  <!-- Tomcat -->
  <logger name="org.apache" level="WARN"/>
  <logger name="org.apache.catalina.startup.DigesterFactory" level="OFF"/>

  <!-- Misc -->
  <logger name="com.sun" level="WARN"/>
  <logger name="sun.rmi" level="WARN"/>
  <logger name="jdk.event.security" level="INFO"/>

  <!-- Dev profile overrides. Niveles configurables via env var:
       LOGGING_LEVEL_ORG_HIBERNATE_SQL para silenciar SQL spam en runs largos. -->
  <springProperty name="hibernate.sql.level" source="logging.level.org.hibernate.SQL" defaultValue="DEBUG"/>
  <springProfile name="dev">
    <logger name="bo.com.sintesis.mdqr" level="DEBUG"/>
    <logger name="org.hibernate.SQL" level="${hibernate.sql.level}"/>
    <logger name="liquibase" level="INFO"/>
  </springProfile>

  <springProperty name="log.level" source="logging.level.root" defaultValue="INFO"/>
  <root level="${log.level}">
    <appender-ref ref="CONSOLE"/>
    <appender-ref ref="ASYNC_FILE"/>
  </root>

  <statusListener class="ch.qos.logback.core.status.NopStatusListener"/>
  <contextListener class="ch.qos.logback.classic.jul.LevelChangePropagator">
    <resetJUL>true</resetJUL>
  </contextListener>

</configuration>
