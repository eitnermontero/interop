<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="003-1" author="middleware-core">
        <createTable tableName="role_menu_action">
            <column name="keycloak_role_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="menu_id" type="bigint">
                <constraints nullable="false"
                             foreignKeyName="fk_rma_menu"
                             references="menu(id)"/>
            </column>
            <column name="action_id" type="bigint">
                <constraints nullable="false"
                             foreignKeyName="fk_rma_action"
                             references="action(id)"/>
            </column>
            <column name="is_granted" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="created_date" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(50)"/>
            <column name="last_modified_date" type="TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="003-2" author="middleware-core">
        <addPrimaryKey tableName="role_menu_action"
                       columnNames="keycloak_role_name, menu_id, action_id"
                       constraintName="pk_role_menu_action"/>
    </changeSet>

    <changeSet id="003-3" author="middleware-core">
        <createIndex tableName="role_menu_action" indexName="idx_rma_role">
            <column name="keycloak_role_name"/>
        </createIndex>
        <createIndex tableName="role_menu_action" indexName="idx_rma_menu">
            <column name="menu_id"/>
        </createIndex>
        <createIndex tableName="role_menu_action" indexName="idx_rma_action">
            <column name="action_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
