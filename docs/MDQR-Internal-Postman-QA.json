  },
  "item": [
    {
      "name": "🔐 Keycloak – Tokens",
      "item": [
        {
          "name": "Obtener token (Client Credentials)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "var resp = pm.response.json();",
            "if (resp.access_token) {",
            "    pm.collectionVariables.set('ADMIN_TOKEN', resp.access_token);",
            "    console.log('✅ ADMIN_TOKEN guardado. Expira en: ' + resp.expires_in + 's');",
            "} else { console.error('❌ Sin token:', JSON.stringify(resp)); }"
          ]}}],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": { "mode": "urlencoded", "urlencoded": [
              { "key": "grant_type",    "value": "client_credentials" },
              { "key": "client_id",     "value": "mdqradminservice" },
              { "key": "client_secret", "value": "mdqradminservice-secret" }
            ]},
            "url": {
              "raw": "http://199.3.0.63:8180/realms/mdqr-admin/protocol/openid-connect/token",
              "protocol": "http", "host": ["199.3.0.63"], "port": "8180",
              "path": ["realms", "mdqr-admin", "protocol", "openid-connect", "token"]
            }
          }
        }
      ]
    },
