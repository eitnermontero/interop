    <changeSet id="008-create-trx-entity-code-table" author="backend-team">
        <comment>Crear tabla trx_entity_code para códigos de entidades financieras</comment>

        <createTable tableName="trx_entity_code">
            <column name="code" type="varchar(20)">
                <constraints primaryKey="true" nullable="false" primaryKeyName="trx_entity_code_pkey"/>
            </column>
            <column name="participant" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="entity_group" type="varchar(10)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <rollback>
            <dropTable tableName="trx_entity_code"/>
        </rollback>
    </changeSet>

