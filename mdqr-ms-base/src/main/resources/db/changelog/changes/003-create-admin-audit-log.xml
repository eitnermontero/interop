<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- ═══════════════════════════════════════════════════════════════════
         Tabla: admin_audit_log
         Auditoría de Acciones Administrativas
         ═══════════════════════════════════════════════════════════════════ -->

    <changeSet id="003-1" author="mdqr">
        <comment>Crear sequence para admin_audit_log</comment>
        <createSequence sequenceName="admin_audit_log_seq" startValue="1" incrementBy="1"/>
    </changeSet>

    <changeSet id="003-2" author="mdqr">
        <comment>Crear tabla admin_audit_log</comment>
        <createTable tableName="admin_audit_log">
            <!-- Primary Key -->
            <column name="id" type="bigint" defaultValueSequenceNext="admin_audit_log_seq">
                <constraints primaryKey="true" primaryKeyName="pk_admin_audit_log"/>
            </column>

            <!-- User Identity (from Keycloak JWT) -->
            <column name="keycloak_user_id" type="varchar(255)"/>

            <column name="keycloak_username" type="varchar(255)"/>

            <!-- Action Details -->
            <column name="action" type="varchar(100)">
                <constraints nullable="false"/>
            </column>

            <column name="resource_type" type="varchar(100)">
                <constraints nullable="false"/>
            </column>

            <column name="resource_id" type="varchar(100)"/>

            <!-- Change Tracking (JSON diff) -->
            <column name="old_value" type="jsonb"/>

            <column name="new_value" type="jsonb"/>

            <!-- Request Context -->
            <column name="ip_address" type="varchar(45)"/>

            <!-- Timestamp -->
            <column name="created_at" type="timestamptz" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="003-3" author="mdqr">
        <comment>Crear índices para admin_audit_log</comment>

        <!-- Búsqueda por usuario -->
        <createIndex tableName="admin_audit_log" indexName="idx_admin_audit_user">
            <column name="keycloak_user_id"/>
        </createIndex>

        <!-- Búsqueda por tipo de acción -->
        <createIndex tableName="admin_audit_log" indexName="idx_admin_audit_action">
            <column name="action"/>
        </createIndex>

        <!-- Ordenamiento por fecha (reportes) -->
        <createIndex tableName="admin_audit_log" indexName="idx_admin_audit_created">
            <column name="created_at" descending="true"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
