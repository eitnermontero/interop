<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="007-1" author="mdqr-team">
        <comment>Crear tabla certificate_audit_log</comment>

        <createSequence sequenceName="certificate_audit_log_id_seq" startValue="1" incrementBy="1"/>

        <createTable tableName="certificate_audit_log">
            <column name="id" type="bigint" defaultValueSequenceNext="certificate_audit_log_id_seq">
                <constraints primaryKey="true" primaryKeyName="pk_certificate_audit_log"/>
            </column>

            <column name="certificate_id" type="bigint"/>
            <column name="serial_number" type="varchar(100)"/>

            <column name="action" type="varchar(50)">
                <constraints nullable="false"/>
            </column>

            <column name="user_id" type="varchar(100)">
                <constraints nullable="false"/>
            </column>

            <column name="user_email" type="varchar(255)"/>
            <column name="ip_address" type="varchar(45)"/>
            <column name="user_agent" type="text"/>

            <column name="timestamp" type="timestamptz" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>

            <column name="before_state" type="jsonb"/>
            <column name="after_state" type="jsonb"/>

            <column name="success" type="boolean">
                <constraints nullable="false"/>
            </column>

            <column name="error_message" type="text"/>
            <column name="error_code" type="varchar(50)"/>

            <column name="request_id" type="varchar(100)"/>
            <column name="entity_id_request" type="varchar(50)"/>
            <column name="qr_content_hash" type="varchar(64)"/>
            <column name="processing_time_ms" type="integer"/>
        </createTable>

        <createIndex tableName="certificate_audit_log" indexName="idx_audit_cert">
            <column name="certificate_id"/>
        </createIndex>

        <createIndex tableName="certificate_audit_log" indexName="idx_audit_serial">
            <column name="serial_number"/>
        </createIndex>

        <createIndex tableName="certificate_audit_log" indexName="idx_audit_action">
            <column name="action"/>
        </createIndex>

        <createIndex tableName="certificate_audit_log" indexName="idx_audit_user">
            <column name="user_id"/>
        </createIndex>

        <createIndex tableName="certificate_audit_log" indexName="idx_audit_timestamp">
            <column name="timestamp"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
