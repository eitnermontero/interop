<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="006-1" author="mdqr-team">
        <comment>Crear tabla certificate_version</comment>

        <createSequence sequenceName="certificate_version_id_seq" startValue="1" incrementBy="1"/>

        <createTable tableName="certificate_version">
            <column name="id" type="bigint" defaultValueSequenceNext="certificate_version_id_seq">
                <constraints primaryKey="true" primaryKeyName="pk_certificate_version"/>
            </column>

            <column name="certificate_id" type="bigint">
                <constraints nullable="false"/>
            </column>

            <column name="version_number" type="integer">
                <constraints nullable="false"/>
            </column>

            <column name="pem_content_snapshot" type="text">
                <constraints nullable="false"/>
            </column>

            <column name="fingerprint_sha256_snapshot" type="varchar(64)">
                <constraints nullable="false"/>
            </column>

            <column name="valid_from_snapshot" type="timestamptz">
                <constraints nullable="false"/>
            </column>

            <column name="valid_to_snapshot" type="timestamptz">
                <constraints nullable="false"/>
            </column>

            <column name="subject_dn_snapshot" type="varchar(500)"/>
            <column name="issuer_dn_snapshot" type="varchar(500)"/>

            <column name="replaced_at" type="timestamptz" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>

            <column name="replaced_by" type="varchar(100)">
                <constraints nullable="false"/>
            </column>

            <column name="change_reason" type="varchar(500)"/>
            <column name="change_type" type="varchar(50)"/>
        </createTable>

        <createIndex tableName="certificate_version" indexName="idx_certver_cert">
            <column name="certificate_id"/>
        </createIndex>

        <createIndex tableName="certificate_version" indexName="idx_certver_replaced">
            <column name="replaced_at"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
