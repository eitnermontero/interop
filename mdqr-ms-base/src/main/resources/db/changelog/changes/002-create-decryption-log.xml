<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- ═══════════════════════════════════════════════════════════════════
         Tabla: decryption_log
         Auditoría de Desencriptaciones de QR
         ═══════════════════════════════════════════════════════════════════ -->

    <changeSet id="002-1" author="mdqr">
        <comment>Crear sequence para decryption_log</comment>
        <createSequence sequenceName="decryption_log_seq" startValue="1" incrementBy="1"/>
    </changeSet>

    <changeSet id="002-2" author="mdqr">
        <comment>Crear tabla decryption_log</comment>
        <createTable tableName="decryption_log">
            <!-- Primary Key -->
            <column name="id" type="bigint" defaultValueSequenceNext="decryption_log_seq">
                <constraints primaryKey="true" primaryKeyName="pk_decryption_log"/>
            </column>

            <!-- Log Identity -->
            <column name="log_id" type="varchar(60)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_decryption_log_id"/>
            </column>

            <!-- Client Identity (Multi-tenant) -->
            <column name="keycloak_client_id" type="varchar(255)">
                <constraints nullable="false"/>
            </column>

            <column name="mtls_cert_cn" type="varchar(255)">
                <constraints nullable="false"/>
            </column>

            <!-- Certificate Reference -->
            <column name="certificate_id" type="bigint">
                <constraints foreignKeyName="fk_decrypt_log_certificate"
                             references="certificate(id)"/>
            </column>

            <!-- QR Data -->
            <column name="qr_string_hash" type="varchar(64)">
                <constraints nullable="false"/>
            </column>

            <column name="entity_id_request" type="varchar(50)"/>

            <column name="external_reference" type="varchar(200)"/>

            <!-- Metadata & Result -->
            <column name="metadata" type="jsonb"/>

            <column name="status" type="varchar(20)">
                <constraints nullable="false"/>
            </column>

            <column name="qr_type" type="varchar(20)"/>

            <column name="decrypted_data_json" type="jsonb"/>

            <column name="error_message" type="text"/>

            <!-- Performance Metrics -->
            <column name="processing_time_ms" type="bigint"/>

            <!-- Request Context -->
            <column name="ip_address" type="varchar(45)"/>

            <column name="user_agent" type="varchar(500)"/>

            <!-- Audit Fields -->
            <column name="created_by" type="varchar(50)">
                <constraints nullable="false"/>
            </column>

            <column name="created_date" type="timestamptz" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="002-3" author="mdqr">
        <comment>Crear índices para decryption_log</comment>

        <!-- Búsqueda por cliente (multi-tenant) -->
        <createIndex tableName="decryption_log" indexName="idx_log_client">
            <column name="keycloak_client_id"/>
        </createIndex>

        <!-- Búsqueda por certificado usado -->
        <createIndex tableName="decryption_log" indexName="idx_log_cert">
            <column name="certificate_id"/>
        </createIndex>

        <!-- Ordenamiento por fecha (reportes) -->
        <createIndex tableName="decryption_log" indexName="idx_log_created">
            <column name="created_date" descending="true"/>
        </createIndex>

        <!-- Filtro por estado -->
        <createIndex tableName="decryption_log" indexName="idx_log_status">
            <column name="status"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
