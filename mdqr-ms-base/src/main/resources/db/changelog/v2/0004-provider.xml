<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        ═══════════════════════════════════════════════════════════════════
        Tablas: provider + provider_credential_ref  (schema public)

        provider: catálogo de proveedores externos (Tuxedo API, otros servicios
          de certificados, APIs de red). Cada fila describe un endpoint externo.

        provider_credential_ref: referencia (no el secreto) a la credencial
          almacenada en Vault. El secreto real vive en Vault KV / Transit;
          aquí se guarda únicamente la ruta y clave para recuperarlo.
          NO almacenar client_secret, API key ni password en esta tabla.

        Locks: ACCESS EXCLUSIVE en CREATE TABLE para cada tabla.
               Objetos nuevos, seguros con tráfico activo.
        Rollback: DROP TABLE en orden inverso (provider_credential_ref primero).
        ═══════════════════════════════════════════════════════════════════
    -->

    <!-- ─────────────────────────────────────────────────────────────────
         1. provider
         ───────────────────────────────────────────────────────────────── -->

    <changeSet id="v2-base-016" author="hub-interop">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="provider" schemaName="public"/></not>
        </preConditions>
        <comment>Crear secuencia para provider</comment>
        <createSequence sequenceName="provider_seq"
                        schemaName="public"
                        startValue="1"
                        incrementBy="1"/>
        <rollback>
            <dropSequence sequenceName="provider_seq" schemaName="public"/>
        </rollback>
    </changeSet>

    <changeSet id="v2-base-017" author="hub-interop">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="provider" schemaName="public"/></not>
        </preConditions>
        <comment>Crear tabla provider — catálogo de proveedores externos</comment>
        <createTable tableName="provider" schemaName="public">

            <column name="id" type="bigint" defaultValueSequenceNext="provider_seq">
                <constraints primaryKey="true" primaryKeyName="pk_provider" nullable="false"/>
            </column>

            <!--
                Código corto único, inmutable, usado en código fuente y configuración.
                Ejemplos: "TUXEDO_CERT", "BCB_QR_API".
            -->
            <column name="code" type="varchar(50)">
                <constraints nullable="false"
                             unique="true"
                             uniqueConstraintName="uk_provider_code"/>
            </column>

            <!-- Nombre descriptivo del proveedor -->
            <column name="name" type="text">
                <constraints nullable="false"/>
            </column>

            <!--
                URL base del proveedor externo (sin path de endpoint específico).
                Ejemplo: "http://localhost:5050"
            -->
            <column name="base_url" type="text">
                <constraints nullable="false"/>
            </column>

            <!-- Estado: ACTIVE / INACTIVE / MAINTENANCE -->
            <column name="status" type="varchar(20)" defaultValue="ACTIVE">
                <constraints nullable="false"/>
            </column>

            <!-- Timeout en milisegundos para llamadas a este proveedor -->
            <column name="timeout_ms" type="integer" defaultValueNumeric="30000">
                <constraints nullable="false"/>
            </column>

            <!-- Metadatos adicionales (headers extra, flags de configuración) -->
            <column name="metadata" type="jsonb"/>

            <!-- Campos de auditoría -->
            <column name="created_by" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="created_date" type="timestamptz" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_by" type="varchar(100)"/>
            <column name="last_modified_date" type="timestamptz"/>
        </createTable>

        <sql>
            ALTER TABLE public.provider
            ADD CONSTRAINT chk_provider_status
            CHECK (status IN ('ACTIVE', 'INACTIVE', 'MAINTENANCE'));
        </sql>

        <sql>
            ALTER TABLE public.provider
            ADD CONSTRAINT chk_provider_timeout
            CHECK (timeout_ms > 0);
        </sql>

        <rollback>
            <sql>ALTER TABLE public.provider DROP CONSTRAINT IF EXISTS chk_provider_status;</sql>
            <sql>ALTER TABLE public.provider DROP CONSTRAINT IF EXISTS chk_provider_timeout;</sql>
            <dropTable tableName="provider" schemaName="public"/>
        </rollback>
    </changeSet>

    <changeSet id="v2-base-018" author="hub-interop">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="provider" schemaName="public"/>
            <not><indexExists indexName="idx_provider_status" schemaName="public"/></not>
        </preConditions>
        <comment>Índices para provider</comment>

        <createIndex tableName="provider"
                     schemaName="public"
                     indexName="idx_provider_status">
            <column name="status"/>
        </createIndex>

        <rollback>
            <dropIndex tableName="provider" schemaName="public" indexName="idx_provider_status"/>
        </rollback>
    </changeSet>

    <!-- ─────────────────────────────────────────────────────────────────
         2. provider_credential_ref
            Referencia a credencial en Vault KV. El secreto (API key,
            client_secret, mTLS cert) NO se almacena aquí.
            vault_path + vault_key identifican la ubicación en Vault.
            Ejemplo: vault_path = "secret/mdqr-decode/providers/tuxedo"
                     vault_key  = "api_key"
         ───────────────────────────────────────────────────────────────── -->

    <changeSet id="v2-base-019" author="hub-interop">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="provider_credential_ref" schemaName="public"/></not>
        </preConditions>
        <comment>Crear secuencia para provider_credential_ref</comment>
        <createSequence sequenceName="provider_credential_ref_seq"
                        schemaName="public"
                        startValue="1"
                        incrementBy="1"/>
        <rollback>
            <dropSequence sequenceName="provider_credential_ref_seq" schemaName="public"/>
        </rollback>
    </changeSet>

    <changeSet id="v2-base-020" author="hub-interop">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="provider_credential_ref" schemaName="public"/></not>
        </preConditions>
        <comment>Crear tabla provider_credential_ref — referencia a secretos en Vault</comment>
        <createTable tableName="provider_credential_ref" schemaName="public">

            <column name="id" type="bigint" defaultValueSequenceNext="provider_credential_ref_seq">
                <constraints primaryKey="true" primaryKeyName="pk_provider_credential_ref" nullable="false"/>
            </column>

            <!-- FK al proveedor dueño de esta credencial -->
            <column name="provider_id" type="bigint">
                <constraints nullable="false"
                             foreignKeyName="fk_provider_cred_provider"
                             references="public.provider(id)"/>
            </column>

            <!--
                Ruta completa en Vault KV donde vive el secreto.
                Ejemplo: "secret/mdqr-decode/providers/tuxedo"
            -->
            <column name="vault_path" type="text">
                <constraints nullable="false"/>
            </column>

            <!--
                Clave dentro del secreto de Vault.
                Ejemplo: "api_key", "client_secret", "mtls_cert".
            -->
            <column name="vault_key" type="varchar(100)">
                <constraints nullable="false"/>
            </column>

            <!--
                Tipo de credencial para que la aplicación sepa cómo usarla.
                Ejemplos: "API_KEY", "BEARER_TOKEN", "MTLS_CERT", "BASIC_AUTH".
            -->
            <column name="credential_type" type="varchar(50)">
                <constraints nullable="false"/>
            </column>

            <!-- Estado: ACTIVE / ROTATED / REVOKED -->
            <column name="status" type="varchar(20)" defaultValue="ACTIVE">
                <constraints nullable="false"/>
            </column>

            <!-- Campos de auditoría -->
            <column name="created_by" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="created_date" type="timestamptz" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_by" type="varchar(100)"/>
            <column name="last_modified_date" type="timestamptz"/>
        </createTable>

        <!--
            UNIQUE (provider_id, credential_type): solo una credencial activa
            de cada tipo por proveedor. Si se rota, la anterior pasa a ROTATED.
        -->
        <addUniqueConstraint tableName="provider_credential_ref"
                             schemaName="public"
                             columnNames="provider_id, credential_type"
                             constraintName="uk_provider_cred_provider_type"/>

        <sql>
            ALTER TABLE public.provider_credential_ref
            ADD CONSTRAINT chk_provider_cred_status
            CHECK (status IN ('ACTIVE', 'ROTATED', 'REVOKED'));
        </sql>

        <rollback>
            <sql>ALTER TABLE public.provider_credential_ref DROP CONSTRAINT IF EXISTS chk_provider_cred_status;</sql>
            <dropUniqueConstraint tableName="provider_credential_ref"
                                  schemaName="public"
                                  constraintName="uk_provider_cred_provider_type"/>
            <dropTable tableName="provider_credential_ref" schemaName="public"/>
        </rollback>
    </changeSet>

    <changeSet id="v2-base-021" author="hub-interop">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="provider_credential_ref" schemaName="public"/>
            <not><indexExists indexName="idx_provider_cred_provider_id" schemaName="public"/></not>
        </preConditions>
        <comment>Índices para provider_credential_ref</comment>

        <!--
            idx_provider_cred_provider_id: listar credenciales de un proveedor.
        -->
        <createIndex tableName="provider_credential_ref"
                     schemaName="public"
                     indexName="idx_provider_cred_provider_id">
            <column name="provider_id"/>
        </createIndex>

        <!--
            idx_provider_cred_status: filtrar credenciales activas.
        -->
        <createIndex tableName="provider_credential_ref"
                     schemaName="public"
                     indexName="idx_provider_cred_status">
            <column name="status"/>
        </createIndex>

        <rollback>
            <dropIndex tableName="provider_credential_ref" schemaName="public" indexName="idx_provider_cred_provider_id"/>
            <dropIndex tableName="provider_credential_ref" schemaName="public" indexName="idx_provider_cred_status"/>
        </rollback>
    </changeSet>

    <!-- ─────────────────────────────────────────────────────────────────
         3. Seed inicial: proveedor Tuxedo existente
            Este changeset registra en el catálogo el proveedor Tuxedo
            que el código de ms-base ya usa vía ApplicationProperties.
            La URL y el API key reales vienen de Vault/env; aquí solo
            se registra la referencia de catálogo.
         ───────────────────────────────────────────────────────────────── -->

    <changeSet id="v2-base-022" author="hub-interop">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="provider" schemaName="public"/>
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM public.provider WHERE code = 'TUXEDO_CERT'
            </sqlCheck>
        </preConditions>
        <comment>Seed: registrar proveedor TUXEDO_CERT en el catálogo</comment>
        <insert tableName="provider" schemaName="public">
            <column name="code"        value="TUXEDO_CERT"/>
            <column name="name"        value="Tuxedo Certificate API (Go)"/>
            <column name="base_url"    value="http://localhost:5050"/>
            <column name="status"      value="ACTIVE"/>
            <column name="timeout_ms"  valueNumeric="30000"/>
            <column name="created_by"  value="hub-interop-migration"/>
        </insert>
        <rollback>
            <delete tableName="provider" schemaName="public">
                <where>code = 'TUXEDO_CERT'</where>
            </delete>
        </rollback>
    </changeSet>

</databaseChangeLog>
