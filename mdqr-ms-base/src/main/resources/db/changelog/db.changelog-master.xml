<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- ═══════════════════════════════════════════════════════════════════
         v2 — Hub Interoperabilidad: auditoría con cadena de hashes,
         outbox transaccional, medición/facturación y catálogo de proveedores.
         Orden obligatorio por FK:
           0001 hub_audit_log        (tabla particionada + tabla de idempotencia)
           0002 outbox_event         (independiente)
           0003 hub_measurement      (independiente)
           0004 provider + provider_credential_ref (FK interna: cred → provider)

         ADR-0006 §9.3: el hub es Modelo A (intermediario) — no persiste campos
         de dominio de cada producto. 0005-caso.xml existe en el repo pero NO se
         aplica: el hub no guarda relato/zona/tags en claro (PII). Si se requiere
         trazabilidad por producto, se creará hub_exchange genérica (payload cifrado
         con Vault Transit). Ver ADR-0006 §9 y §15.1.
         ═══════════════════════════════════════════════════════════════════ -->
    <include file="v2/0001-hub-audit-log.xml"   relativeToChangelogFile="true"/>
    <include file="v2/0002-outbox-event.xml"    relativeToChangelogFile="true"/>
    <include file="v2/0003-hub-measurement.xml" relativeToChangelogFile="true"/>
    <include file="v2/0004-provider.xml"        relativeToChangelogFile="true"/>

</databaseChangeLog>
