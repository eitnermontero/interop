<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="005-1" author="hub">
        <addColumn tableName="audit_log">
            <column name="tenant_id" type="VARCHAR(50)"/>
        </addColumn>
        <addColumn tableName="audit_log">
            <column name="req_id" type="VARCHAR(128)"/>
        </addColumn>
    </changeSet>

    <changeSet id="005-2" author="hub">
        <createIndex tableName="audit_log" indexName="idx_audit_tenant_id">
            <column name="tenant_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
