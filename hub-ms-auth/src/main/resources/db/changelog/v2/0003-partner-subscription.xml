<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        ═══════════════════════════════════════════════════════════════════
        Tabla: partner_subscription  (schema admin)
        Suscripción de un partner a un producto del hub.
        Cada fila representa un producto contratado, con su scope OAuth2,
        límites de rate-limit, IPs permitidas y ventana de vigencia.
        ═══════════════════════════════════════════════════════════════════
        Prerequisito: 0001-partner.xml (FK a admin.partner.id).
        Locks: ACCESS EXCLUSIVE en CREATE TABLE. Tabla nueva, seguro con
               tráfico activo.
        Rollback: DROP TABLE + DROP SEQUENCE + DROP INDEX.
        ═══════════════════════════════════════════════════════════════════
    -->

    <changeSet id="v2-auth-007" author="hub-interop">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="partner_subscription" schemaName="admin"/></not>
        </preConditions>
        <comment>Crear secuencia para partner_subscription</comment>
        <createSequence sequenceName="partner_subscription_seq"
                        schemaName="admin"
                        startValue="1"
                        incrementBy="1"/>
        <rollback>
            <dropSequence sequenceName="partner_subscription_seq" schemaName="admin"/>
        </rollback>
    </changeSet>

    <changeSet id="v2-auth-008" author="hub-interop">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="partner_subscription" schemaName="admin"/></not>
        </preConditions>
        <comment>Crear tabla partner_subscription — suscripciones de partners a productos</comment>
        <createTable tableName="partner_subscription" schemaName="admin">

            <column name="id" type="bigint" defaultValueSequenceNext="partner_subscription_seq">
                <constraints primaryKey="true" primaryKeyName="pk_partner_subscription" nullable="false"/>
            </column>

            <!-- FK al partner suscrito -->
            <column name="partner_id" type="bigint">
                <constraints nullable="false"
                             foreignKeyName="fk_partner_sub_partner"
                             references="admin.partner(id)"/>
            </column>

            <!--
                Código del producto contratado.
                Ejemplos: "CASO_PENAL", "PAYMENT_QUERY", "BALANCE_QUERY".
                Catálogo externo al modelo de DB; se valida en la aplicación.
            -->
            <column name="product_code" type="varchar(100)">
                <constraints nullable="false"/>
            </column>

            <!--
                Scope OAuth2 asociado a esta suscripción.
                Debe coincidir con el scope configurado en el JWT del partner.
                Ejemplo: "https://api.sintesis.com.bo/caso.penal"
            -->
            <column name="scope" type="text">
                <constraints nullable="false"/>
            </column>

            <!-- Estado: ACTIVE / SUSPENDED / CANCELLED -->
            <column name="status" type="varchar(20)" defaultValue="ACTIVE">
                <constraints nullable="false"/>
            </column>

            <!--
                Límite de requests por minuto (rate limit).
                NULL = sin límite explícito (hereda el default del gateway).
            -->
            <column name="rate_limit_rpm" type="integer"/>

            <!--
                IPs o CIDRs permitidos, almacenados como array de texto.
                Ejemplo: {"192.168.1.0/24","10.0.0.5"}
                NULL = sin restricción de IP (se aplica el whitelist del gateway).
            -->
            <column name="allowed_ips" type="text[]"/>

            <!-- Vigencia de la suscripción -->
            <column name="valid_from" type="timestamptz">
                <constraints nullable="false"/>
            </column>
            <column name="valid_to" type="timestamptz"/>

            <!-- Campos de auditoría -->
            <column name="created_by" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="created_date" type="timestamptz" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_by" type="varchar(100)"/>
            <column name="last_modified_date" type="timestamptz"/>
        </createTable>

        <!--
            UNIQUE (partner_id, product_code): un partner no puede tener dos
            suscripciones activas al mismo producto simultáneamente.
            Si se necesita historial, se aplica el patrón expand/contract
            añadiendo una columna de versión o usando valid_to para marcar expiración.
        -->
        <addUniqueConstraint tableName="partner_subscription"
                             schemaName="admin"
                             columnNames="partner_id, product_code"
                             constraintName="uk_partner_sub_partner_product"/>

        <!-- CHECK de status -->
        <sql>
            ALTER TABLE admin.partner_subscription
            ADD CONSTRAINT chk_partner_sub_status
            CHECK (status IN ('ACTIVE', 'SUSPENDED', 'CANCELLED'));
        </sql>

        <!-- CHECK: rate_limit_rpm positivo si se especifica -->
        <sql>
            ALTER TABLE admin.partner_subscription
            ADD CONSTRAINT chk_partner_sub_rate_limit
            CHECK (rate_limit_rpm IS NULL OR rate_limit_rpm > 0);
        </sql>

        <!-- CHECK: valid_to > valid_from si se especifica -->
        <sql>
            ALTER TABLE admin.partner_subscription
            ADD CONSTRAINT chk_partner_sub_validity
            CHECK (valid_to IS NULL OR valid_to > valid_from);
        </sql>

        <rollback>
            <sql>ALTER TABLE admin.partner_subscription DROP CONSTRAINT IF EXISTS chk_partner_sub_status;</sql>
            <sql>ALTER TABLE admin.partner_subscription DROP CONSTRAINT IF EXISTS chk_partner_sub_rate_limit;</sql>
            <sql>ALTER TABLE admin.partner_subscription DROP CONSTRAINT IF EXISTS chk_partner_sub_validity;</sql>
            <dropUniqueConstraint tableName="partner_subscription"
                                  schemaName="admin"
                                  constraintName="uk_partner_sub_partner_product"/>
            <dropTable tableName="partner_subscription" schemaName="admin"/>
        </rollback>
    </changeSet>

    <changeSet id="v2-auth-009" author="hub-interop">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="partner_subscription" schemaName="admin"/>
            <not><indexExists indexName="idx_partner_sub_partner_id" schemaName="admin"/></not>
        </preConditions>
        <comment>Índices para partner_subscription</comment>

        <!--
            idx_partner_sub_partner_id: listar suscripciones de un partner.
        -->
        <createIndex tableName="partner_subscription"
                     schemaName="admin"
                     indexName="idx_partner_sub_partner_id">
            <column name="partner_id"/>
        </createIndex>

        <!--
            idx_partner_sub_product_status: filtrar suscripciones activas por producto.
            Patrón: el gateway consulta los límites de rate-limit por product_code.
        -->
        <createIndex tableName="partner_subscription"
                     schemaName="admin"
                     indexName="idx_partner_sub_product_status">
            <column name="product_code"/>
            <column name="status"/>
        </createIndex>

        <!--
            idx_partner_sub_valid_to: job de expiración de suscripciones.
        -->
        <createIndex tableName="partner_subscription"
                     schemaName="admin"
                     indexName="idx_partner_sub_valid_to">
            <column name="valid_to"/>
        </createIndex>

        <rollback>
            <dropIndex tableName="partner_subscription" schemaName="admin" indexName="idx_partner_sub_partner_id"/>
            <dropIndex tableName="partner_subscription" schemaName="admin" indexName="idx_partner_sub_product_status"/>
            <dropIndex tableName="partner_subscription" schemaName="admin" indexName="idx_partner_sub_valid_to"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
