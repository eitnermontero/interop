# ─── Nexus Repository (required for SDK dependency) ─────────────────
NEXUS_USERNAME=
NEXUS_PASSWORD=

# ─── Vault (auto-generated by scripts/vault-init.sh) ────────────────
VAULT_UNSEAL_KEY=
VAULT_ROOT_TOKEN=
VAULT_ROLE_ID=
VAULT_SECRET_ID=

# ─── Keycloak Sync (used by scripts/keycloak-sync.sh) ───────────────
KC_URL=http://localhost:8180
KC_REALM=mdqr-auth
KC_SERVICE_CLIENT=mdqr-auth-api
KC_USERNAME=admin
KC_PASSWORD=admin

# ═════════════════════════════════════════════════════════════════════
# MDQR (QR Decrypt System)
# ═════════════════════════════════════════════════════════════════════

# ─── MDQR Database ───────────────────────────────────────────────────
MDQR_DB_NAME=hub_interop
MDQR_DB_USER=mdqr_app
MDQR_DB_PASSWORD=mdqr_secure_password_here

# ─── Tuxedo Certificate API (Go) ─────────────────────────────────────
TUXEDO_API_URL=http://localhost:5050
TUXEDO_API_KEY=your-secret-token-here

# ─── mTLS Keystores (for mdqr-ms-base) ───────────────────────────────
SERVER_KEYSTORE_PASSWORD=changeit
TRUSTSTORE_PASSWORD=changeit

# ─── Keycloak MDQR Realm ─────────────────────────────────────────────
KC_MDQR_REALM=middleware-qr
KC_MDQR_SERVICE_CLIENT=mdqr-api
