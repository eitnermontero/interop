# ─── Nexus Repository (required for SDK dependency) ─────────────────
NEXUS_USERNAME=
NEXUS_PASSWORD=

# ─── Vault (auto-generated by scripts/vault-init.sh) ────────────────
VAULT_UNSEAL_KEY=
VAULT_ROOT_TOKEN=
VAULT_ROLE_ID=
VAULT_SECRET_ID=

# ─── Keycloak Sync (used by scripts/keycloak-sync.sh) ───────────────
KC_URL=http://localhost:8180
KC_REALM=hub-auth
KC_SERVICE_CLIENT=hub-auth-api
KC_USERNAME=admin
KC_PASSWORD=admin

# ═════════════════════════════════════════════════════════════════════
# HUB (QR Decrypt System)
# ═════════════════════════════════════════════════════════════════════

# ─── HUB Database ───────────────────────────────────────────────────
HUB_DB_NAME=hub_interop
HUB_DB_USER=hub_app
HUB_DB_PASSWORD=hub_secure_password_here

# ─── Tuxedo Certificate API (Go) ─────────────────────────────────────
TUXEDO_API_URL=http://localhost:5050
TUXEDO_API_KEY=your-secret-token-here

# ─── mTLS Keystores (for hub-ms-base) ───────────────────────────────
SERVER_KEYSTORE_PASSWORD=changeit
TRUSTSTORE_PASSWORD=changeit

# ─── Keycloak HUB Realm ─────────────────────────────────────────────
KC_HUB_REALM=middleware-qr
KC_HUB_SERVICE_CLIENT=hub-api
