root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.java]
indent_size = 4

[*.{yml,yaml}]
indent_size = 2

[*.{json,xml}]
indent_size = 2

[*.{gradle,gradle.kts}]
indent_size = 4

[*.properties]
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[Dockerfile*]
indent_size = 2

[*.{sh,zsh,bash}]
indent_size = 2

[Makefile]
indent_style = tab
