# =============================================================================
#  HUB / PRODUCTION (services stack)
#
#  PREREQUISITOS antes de levantar:
#    1. docker network create --driver bridge --opt com.docker.network.driver.mtu=1500 hub-shared
#    2. Levantar deploy/tools/ (Keycloak, Consul, Vault, Redis)
#    3. Crear las bases de datos PostgreSQL (ver sección DATABASES)
#    4. Ejecutar vault-seed.sh para sembrar secretos
#    5. Ejecutar keycloak-sync-admin.sh + keycloak-sync-partner.sh
#    6. Construir y publicar imágenes Docker al registry
#
#  Copiar como .env y completar los valores <REQUERIDO>.
#  Convencion de placeholders: <NOMBRE> = valor real, sin los <>.
#
#  Sync:  deploy/scripts/env-sync.sh production
# =============================================================================


# =============================================================================
#  1. COMMON
# =============================================================================

#HUB_STACK_NAME=hub-prod-services
#HUB_NETWORK_NAME=hub-prod-net
#HUB_NETWORK_MTU=1500

# Sufijo multi-tenant (dejar vacío en single-tenant). Siempre declarado para
# evitar warnings con la expansión ${TENANT_ID:+-}${TENANT_ID}.
TENANT_ID=

# Índice del nodo en este host. Sufija container_name, hostname,
# Consul instance-id y log file. El service-name en Consul NO lleva índice.
#   server1 → NODE_INDEX=1   server2 → NODE_INDEX=2
NODE_INDEX=1

# Perfiles extra (escala vertical en el mismo host).
# Activar el profile correspondiente y asignar un NODE_INDEX_*_EXTRA único globalmente.
#COMPOSE_PROFILES=
#NODE_INDEX_GATEWAY_EXTRA=99
#NODE_INDEX_BASE_EXTRA=99
#NODE_INDEX_ADMIN_EXTRA=99

# Directorio de logs en el host
#LOG_DIR=/var/log/hub


# =============================================================================
#  2. DOCKER IMAGES + VERSIONS
# =============================================================================
# Registry de producción (sin "-dev"). Descomentar y ajustar al release.

HUB_GATEWAY_IMAGE=cr.sintesis.com.bo/hub/hub-gateway
HUB_BASE_IMAGE=cr.sintesis.com.bo/hub/hub-base-service
HUB_ADMIN_IMAGE=cr.sintesis.com.bo/hub/hub-admin-service
HUB_ADMIN_FE_IMAGE=cr.sintesis.com.bo/hub/hub-admin-fe
HUB_PUBLIC_FE_IMAGE=cr.sintesis.com.bo/hub/hub-public-fe

# Tag exacto a desplegar. Cambiar solo aquí en cada release.
HUB_GATEWAY_VERSION=1.0.0
HUB_BASE_VERSION=1.0.0
HUB_ADMIN_VERSION=1.0.0
HUB_ADMIN_FE_VERSION=1.0.0
HUB_PUBLIC_FE_VERSION=1.0.0

# Spring profiles activos
HUB_GATEWAY_PROFILE=prod
HUB_BASE_PROFILE=prod
HUB_ADMIN_PROFILE=prod


# =============================================================================
#  2b. mTLS — Gateway
#  Generar PKI con:  deploy/scripts/create-pki.sh --partner unilink-api
#  Los certs se montan en /certs/ desde HUB_CERTS_DIR (ver 001-gateway.yml).
# =============================================================================

# Directorio del host donde viven los certs generados por create-pki.sh
HUB_CERTS_DIR=/srv/interop/deploy/certs

# Passwords de los keystores PKCS12 (deben coincidir con los usados al crear la PKI)
HUB_SSL_KEYSTORE_PASSWORD=changeit
HUB_SSL_TRUSTSTORE_PASSWORD=changeit

# Puerto HTTPS/mTLS del gateway (default 8443)
#HUB_GATEWAY_PORT=0.0.0.0:8443
# Puerto management HTTP (solo localhost, para healthchecks)
#HUB_GATEWAY_MGMT_PORT=127.0.0.1:8080


# =============================================================================
#  3. TOOLS (Consul / Redis / Vault / Keycloak)
#     En prod las tools viven en deploy/tools/ en el mismo servidor.
#     Los servicios las alcanzan vía extra_hosts (host-gateway → IP real del host).
# =============================================================================

# --- Consul ---
HUB_CONSUL_HOST=host.docker.internal
#HUB_CONSUL_PORT=8500
#HUB_CONSUL_SCHEME=http
#HUB_CONSUL_TOKEN=

# --- Redis ---
HUB_REDIS_HOST=host.docker.internal
#HUB_REDIS_PORT=6379
# Redis cluster (si deploy/tools/ levantó con profile cluster):
#HUB_REDIS_CLUSTER_ENABLED=true
#HUB_REDIS_NODES=redis://127.0.0.1:6379,redis://127.0.0.1:6380,redis://127.0.0.1:6381
#HUB_REDIS_CLUSTER_NODES=127.0.0.1:6379,127.0.0.1:6380,127.0.0.1:6381

# --- Vault ---
HUB_VAULT_HOST=host.docker.internal
#HUB_VAULT_PORT=8200
#HUB_VAULT_SCHEME=http
# TOKEN es suficiente para single-node. Usar APPROLE en cluster Vault.
HUB_VAULT_AUTHENTICATION=TOKEN
HUB_VAULT_TOKEN=<VAULT_ROOT_TOKEN>
# AppRole (si HUB_VAULT_AUTHENTICATION=APPROLE):
#HUB_VAULT_ROLE_ID=<VAULT_APPROLE_ROLE_ID>
#HUB_VAULT_SECRET_ID=<VAULT_APPROLE_SECRET_ID>
# KV mount: 'secret' (dev/single) o 'kv' (cluster raft).
#HUB_VAULT_KV_BACKEND=secret
#HUB_VAULT_NAMESPACE_BASE=hub

# --- Keycloak ---
# URL que el browser y los JWT issuers usan. Debe coincidir con el iss del token.
# IMPORTANTE: usar IP o hostname real del servidor (no host.docker.internal).
HUB_KEYCLOAK_URL=http://<SERVER_IP_OR_HOSTNAME>:8180
# external-url = lo que Keycloak embebe en el JWT iss. Por default = HUB_KEYCLOAK_URL.
#HUB_KEYCLOAK_EXTERNAL_URL=
#HUB_KEYCLOAK_REALM_BASE=hub

# Keycloak Event Listener webhook secret (si SPI keycloak-http-event-listener está instalado).
# En producción leer desde Vault (audit/keycloak-secret). Override solo si se omite Vault.
#HUB_ADMIN_AUDIT_KC_SECRET=


# =============================================================================
#  4. GATEWAY
# =============================================================================
# Puerto HTTPS/mTLS. El puerto management (healthcheck) queda en 127.0.0.1:8080.
HUB_GATEWAY_PORT=0.0.0.0:8443
# Nodo extra (profile gateway-extra):
#HUB_GATEWAY_PORT_EXTRA=0.0.0.0:8446

# CORS — restringir al dominio del frontend en producción.
# El browser conecta al gateway via https://<IP>:8443 (o vía nginx en 443).
HUB_GATEWAY_CORS_ALLOWED_ORIGINS=http://<SERVER_IP_OR_HOSTNAME>:8081
#HUB_GATEWAY_CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
#HUB_GATEWAY_CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Request-Id
#HUB_GATEWAY_CORS_ALLOW_CREDENTIALS=true

# Resource limits
#HUB_GATEWAY_MEM_LIMIT=768M
#HUB_GATEWAY_MEM_RESERVATION=384M
#HUB_GATEWAY_JAVA_OPTS=

# Log level
#HUB_GATEWAY_LOG_LEVEL=INFO
#HUB_GATEWAY_ROOT_LOG_LEVEL=INFO


# =============================================================================
#  5. BASE-SERVICE  (hub-ms-base)
# =============================================================================
# Nodo extra (profile base-extra):
#HUB_BASE_PORT_EXTRA=127.0.0.1:8092

# Resource limits
#HUB_BASE_MEM_LIMIT=1024M
#HUB_BASE_MEM_RESERVATION=512M
#HUB_BASE_JAVA_OPTS=

# Database — PostgreSQL instalado en el host (host.docker.internal:5432)
# Base de datos: hub_interop
HUB_BASE_DB_URL=jdbc:postgresql://host.docker.internal:5432/hub_interop
# username/password se leen desde Vault (secret/hub-base/system/database).
# Descomentar solo si se omite Vault.
#HUB_BASE_DB_USER=<DB_USER>
#HUB_BASE_DB_PASSWORD=<DB_PASSWORD>
#HUB_BASE_LIQUIBASE_ENABLED=true

# Log levels
#HUB_BASE_LOG_LEVEL=INFO
#HUB_BASE_ROOT_LOG_LEVEL=INFO
#HUB_BASE_LOG_LEVEL_HIBERNATE_SQL=WARN
#HUB_BASE_LOG_LEVEL_HIBERNATE_BIND=WARN


# =============================================================================
#  6. ADMIN-SERVICE  (hub-ms-auth)
# =============================================================================
# Nodo extra (profile admin-extra):
#HUB_ADMIN_PORT_EXTRA=127.0.0.1:8093

# Resource limits
#HUB_ADMIN_MEM_LIMIT=1024M
#HUB_ADMIN_MEM_RESERVATION=512M
#HUB_ADMIN_JAVA_OPTS=

# Database — PostgreSQL instalado en el host (host.docker.internal:5432)
# Base de datos: hub_auth
HUB_ADMIN_DB_URL=jdbc:postgresql://host.docker.internal:5432/hub_auth
# username/password se leen desde Vault (secret/hub-auth/system/database).
# Descomentar solo si se omite Vault.
#HUB_ADMIN_DB_USER=<DB_USER>
#HUB_ADMIN_DB_PASSWORD=<DB_PASSWORD>

# Log levels
#HUB_ADMIN_LOG_LEVEL=INFO
#HUB_ADMIN_ROOT_LOG_LEVEL=INFO


# =============================================================================
#  7. FRONTENDS
# =============================================================================
# admin-fe: panel de administración (Angular SPA)
HUB_ADMIN_FE_PORT=0.0.0.0:8081

# URL del gateway que el browser usará para las llamadas API
APP_API_URL=http://<SERVER_IP_OR_HOSTNAME>:8080

# Keycloak URL y realm para el SPA (debe ser alcanzable desde el browser)
APP_KEYCLOAK_URL=http://<SERVER_IP_OR_HOSTNAME>:8180
APP_KEYCLOAK_REALM=hub-admin
APP_KEYCLOAK_CLIENT_ID=hub-admin-fe
APP_NAME=HUB Admin
#HUB_ADMIN_FE_BASE_PATH=/

# public-fe: portal público (si aplica)
HUB_PUBLIC_FE_PORT=0.0.0.0:8082
#HUB_PUBLIC_FE_BASE_PATH=/


# =============================================================================
#  8. LOGGING + RETENCIÓN
# =============================================================================
#HUB_LOG_MAX_FILE_SIZE=1GB
#HUB_LOG_MAX_HISTORY=180


# =============================================================================
#  9. HEALTHCHECKS
# =============================================================================
#HUB_HC_API_INTERVAL=30s
#HUB_HC_API_TIMEOUT=10s
#HUB_HC_API_RETRIES=3
#HUB_HC_API_START_PERIOD=60s

#HUB_HC_WEB_INTERVAL=30s
#HUB_HC_WEB_TIMEOUT=5s
#HUB_HC_WEB_RETRIES=3
#HUB_HC_WEB_START_PERIOD=10s
