# =============================================================================
#  MDQR / PRODUCTION (services stack)
#
#  PREREQUISITOS antes de levantar:
#    1. docker network create --driver bridge --opt com.docker.network.driver.mtu=1500 mdqr-shared
#    2. Levantar deploy/tools/ (Keycloak, Consul, Vault, Redis)
#    3. Crear las bases de datos PostgreSQL (ver sección DATABASES)
#    4. Ejecutar vault-seed.sh para sembrar secretos
#    5. Ejecutar keycloak-sync-admin.sh + keycloak-sync-partner.sh
#    6. Construir y publicar imágenes Docker al registry
#
#  Copiar como .env y completar los valores <REQUERIDO>.
#  Convencion de placeholders: <NOMBRE> = valor real, sin los <>.
#
#  Sync:  deploy/scripts/env-sync.sh production
# =============================================================================


# =============================================================================
#  1. COMMON
# =============================================================================

#MDQR_STACK_NAME=mdqr-prod-services
#MDQR_NETWORK_NAME=mdqr-prod-net
#MDQR_NETWORK_MTU=1500

# Sufijo multi-tenant (dejar vacío en single-tenant). Siempre declarado para
# evitar warnings con la expansión ${TENANT_ID:+-}${TENANT_ID}.
TENANT_ID=

# Índice del nodo en este host. Sufija container_name, hostname,
# Consul instance-id y log file. El service-name en Consul NO lleva índice.
#   server1 → NODE_INDEX=1   server2 → NODE_INDEX=2
NODE_INDEX=1

# Perfiles extra (escala vertical en el mismo host).
# Activar el profile correspondiente y asignar un NODE_INDEX_*_EXTRA único globalmente.
#COMPOSE_PROFILES=
#NODE_INDEX_GATEWAY_EXTRA=99
#NODE_INDEX_DECRYPT_EXTRA=99
#NODE_INDEX_ADMIN_EXTRA=99

# Directorio de logs en el host
#LOG_DIR=/var/log/mdqr


# =============================================================================
#  2. DOCKER IMAGES + VERSIONS
# =============================================================================
# Registry de producción (sin "-dev"). Descomentar y ajustar al release.

MDQR_GATEWAY_IMAGE=cr.sintesis.com.bo/mdqr/mdqr-gateway
MDQR_DECRYPT_IMAGE=cr.sintesis.com.bo/mdqr/mdqr-decode-service
MDQR_ADMIN_IMAGE=cr.sintesis.com.bo/mdqr/mdqr-admin-service
MDQR_ADMIN_FE_IMAGE=cr.sintesis.com.bo/mdqr/mdqr-admin-fe
MDQR_PUBLIC_FE_IMAGE=cr.sintesis.com.bo/mdqr/mdqr-public-fe

# Tag exacto a desplegar. Cambiar solo aquí en cada release.
MDQR_GATEWAY_VERSION=1.0.0
MDQR_DECRYPT_VERSION=1.0.0
MDQR_ADMIN_VERSION=1.0.0
MDQR_ADMIN_FE_VERSION=1.0.0
MDQR_PUBLIC_FE_VERSION=1.0.0

# Spring profiles activos
MDQR_GATEWAY_PROFILE=prod
MDQR_DECRYPT_PROFILE=prod
MDQR_ADMIN_PROFILE=prod


# =============================================================================
#  3. TOOLS (Consul / Redis / Vault / Keycloak)
#     En prod las tools viven en deploy/tools/ en el mismo servidor.
#     Los servicios las alcanzan vía extra_hosts (host-gateway → IP real del host).
# =============================================================================

# --- Consul ---
MDQR_CONSUL_HOST=host.docker.internal
#MDQR_CONSUL_PORT=8500
#MDQR_CONSUL_SCHEME=http
#MDQR_CONSUL_TOKEN=

# --- Redis ---
MDQR_REDIS_HOST=host.docker.internal
#MDQR_REDIS_PORT=6379
# Redis cluster (si deploy/tools/ levantó con profile cluster):
#MDQR_REDIS_CLUSTER_ENABLED=true
#MDQR_REDIS_NODES=redis://127.0.0.1:6379,redis://127.0.0.1:6380,redis://127.0.0.1:6381
#MDQR_REDIS_CLUSTER_NODES=127.0.0.1:6379,127.0.0.1:6380,127.0.0.1:6381

# --- Vault ---
MDQR_VAULT_HOST=host.docker.internal
#MDQR_VAULT_PORT=8200
#MDQR_VAULT_SCHEME=http
# TOKEN es suficiente para single-node. Usar APPROLE en cluster Vault.
MDQR_VAULT_AUTHENTICATION=TOKEN
MDQR_VAULT_TOKEN=<VAULT_ROOT_TOKEN>
# AppRole (si MDQR_VAULT_AUTHENTICATION=APPROLE):
#MDQR_VAULT_ROLE_ID=<VAULT_APPROLE_ROLE_ID>
#MDQR_VAULT_SECRET_ID=<VAULT_APPROLE_SECRET_ID>
# KV mount: 'secret' (dev/single) o 'kv' (cluster raft).
#MDQR_VAULT_KV_BACKEND=secret
#MDQR_VAULT_NAMESPACE_BASE=mdqr

# --- Keycloak ---
# URL que el browser y los JWT issuers usan. Debe coincidir con el iss del token.
# IMPORTANTE: usar IP o hostname real del servidor (no host.docker.internal).
MDQR_KEYCLOAK_URL=http://<SERVER_IP_OR_HOSTNAME>:8180
# external-url = lo que Keycloak embebe en el JWT iss. Por default = MDQR_KEYCLOAK_URL.
#MDQR_KEYCLOAK_EXTERNAL_URL=
#MDQR_KEYCLOAK_REALM_BASE=mdqr

# Keycloak Event Listener webhook secret (si SPI keycloak-http-event-listener está instalado).
# En producción leer desde Vault (audit/keycloak-secret). Override solo si se omite Vault.
#MDQR_ADMIN_AUDIT_KC_SECRET=


# =============================================================================
#  4. GATEWAY
# =============================================================================
MDQR_GATEWAY_PORT=0.0.0.0:8080
# Nodo extra (profile gateway-extra):
#MDQR_GATEWAY_PORT_EXTRA=0.0.0.0:8086

# CORS — restringir al dominio del frontend en producción.
MDQR_GATEWAY_CORS_ALLOWED_ORIGINS=http://<SERVER_IP_OR_HOSTNAME>:8081
#MDQR_GATEWAY_CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
#MDQR_GATEWAY_CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Request-Id
#MDQR_GATEWAY_CORS_ALLOW_CREDENTIALS=true

# Resource limits
#MDQR_GATEWAY_MEM_LIMIT=768M
#MDQR_GATEWAY_MEM_RESERVATION=384M
#MDQR_GATEWAY_JAVA_OPTS=

# Log level
#MDQR_GATEWAY_LOG_LEVEL=INFO
#MDQR_GATEWAY_ROOT_LOG_LEVEL=INFO


# =============================================================================
#  5. DECRYPT-SERVICE  (mdqr-ms-base)
# =============================================================================
# Nodo extra (profile decrypt-extra):
#MDQR_DECRYPT_PORT_EXTRA=127.0.0.1:8092

# Resource limits
#MDQR_DECRYPT_MEM_LIMIT=1024M
#MDQR_DECRYPT_MEM_RESERVATION=512M
#MDQR_DECRYPT_JAVA_OPTS=

# Database — PostgreSQL instalado en el host (host.docker.internal:5432)
# Base de datos: mdqr_decode
MDQR_DECRYPT_DB_URL=jdbc:postgresql://host.docker.internal:5432/mdqr_decode
# username/password se leen desde Vault (secret/mdqr-decode/system/database).
# Descomentar solo si se omite Vault.
#MDQR_DECRYPT_DB_USER=<DB_USER>
#MDQR_DECRYPT_DB_PASSWORD=<DB_PASSWORD>
#MDQR_DECRYPT_LIQUIBASE_ENABLED=true

# Log levels
#MDQR_DECRYPT_LOG_LEVEL=INFO
#MDQR_DECRYPT_ROOT_LOG_LEVEL=INFO
#MDQR_DECRYPT_LOG_LEVEL_HIBERNATE_SQL=WARN
#MDQR_DECRYPT_LOG_LEVEL_HIBERNATE_BIND=WARN


# =============================================================================
#  6. ADMIN-SERVICE  (mdqr-ms-auth)
# =============================================================================
# Nodo extra (profile admin-extra):
#MDQR_ADMIN_PORT_EXTRA=127.0.0.1:8093

# Resource limits
#MDQR_ADMIN_MEM_LIMIT=1024M
#MDQR_ADMIN_MEM_RESERVATION=512M
#MDQR_ADMIN_JAVA_OPTS=

# Database — PostgreSQL instalado en el host (host.docker.internal:5432)
# Base de datos: mdqr_auth
MDQR_ADMIN_DB_URL=jdbc:postgresql://host.docker.internal:5432/mdqr_auth
# username/password se leen desde Vault (secret/mdqr-auth/system/database).
# Descomentar solo si se omite Vault.
#MDQR_ADMIN_DB_USER=<DB_USER>
#MDQR_ADMIN_DB_PASSWORD=<DB_PASSWORD>

# Log levels
#MDQR_ADMIN_LOG_LEVEL=INFO
#MDQR_ADMIN_ROOT_LOG_LEVEL=INFO


# =============================================================================
#  7. FRONTENDS
# =============================================================================
# admin-fe: panel de administración (Angular SPA)
MDQR_ADMIN_FE_PORT=0.0.0.0:8081

# URL del gateway que el browser usará para las llamadas API
APP_API_URL=http://<SERVER_IP_OR_HOSTNAME>:8080

# Keycloak URL y realm para el SPA (debe ser alcanzable desde el browser)
APP_KEYCLOAK_URL=http://<SERVER_IP_OR_HOSTNAME>:8180
APP_KEYCLOAK_REALM=mdqr-admin
APP_KEYCLOAK_CLIENT_ID=mdqr-admin-fe
APP_NAME=MDQR Admin
#MDQR_ADMIN_FE_BASE_PATH=/

# public-fe: portal público (si aplica)
MDQR_PUBLIC_FE_PORT=0.0.0.0:8082
#MDQR_PUBLIC_FE_BASE_PATH=/


# =============================================================================
#  8. LOGGING + RETENCIÓN
# =============================================================================
#MDQR_LOG_MAX_FILE_SIZE=1GB
#MDQR_LOG_MAX_HISTORY=180


# =============================================================================
#  9. HEALTHCHECKS
# =============================================================================
#MDQR_HC_API_INTERVAL=30s
#MDQR_HC_API_TIMEOUT=10s
#MDQR_HC_API_RETRIES=3
#MDQR_HC_API_START_PERIOD=60s

#MDQR_HC_WEB_INTERVAL=30s
#MDQR_HC_WEB_TIMEOUT=5s
#MDQR_HC_WEB_RETRIES=3
#MDQR_HC_WEB_START_PERIOD=10s
