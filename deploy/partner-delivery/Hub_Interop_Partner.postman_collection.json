        {
          "name": "Detalle de operativo (por cud)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Tiene correlationId', function() {",
                  "    pm.expect(pm.response.json().correlationId).to.exist;",
                  "});",
                  "console.log('Status:', pm.response.code, '- revisar 200 (encontrado) vs 502 (cud inexistente en el backend)');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Correlation-ID",
                "value": "{{$guid}}",
                "description": "ID de correlación único por request (UUID autogenerado)"
              }
            ],
            "url": {
              "raw": "{{base_url}}/interop/v1/inbound/OPERATIVO_DETALLE/v1?cud={{cud_ejemplo}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "interop",
                "v1",
                "inbound",
                "OPERATIVO_DETALLE",
                "v1"
              ],
              "query": [
                {
                  "key": "cud",
                  "value": "{{cud_ejemplo}}"
                }
              ]
            },
            "description": "Detalle de un operativo por su Código Único de Denuncia (cud). 'cud' es REQUERIDO como query param (no como segmento de la URL). Si falta, responde 400 VALIDATION_ERROR. Reemplace {{cud_ejemplo}} por un cud real del entorno de pruebas."
          },
          "response": []
