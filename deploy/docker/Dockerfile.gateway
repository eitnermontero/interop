FROM eclipse-temurin:25-jre-alpine
RUN addgroup -S hub && adduser -S -G hub hub
WORKDIR /app
COPY --chown=hub:hub hub-gateway/build/libs/hub-gateway-*.jar /app/app.jar
USER hub
EXPOSE 8443 8080
ENTRYPOINT ["java", \
    "--enable-native-access=ALL-UNNAMED", \
    "-XX:+UseG1GC", \
    "-XX:MaxRAMPercentage=75.0", \
    "-Djava.security.egd=file:/dev/./urandom", \
    "-jar", "/app/app.jar"]
