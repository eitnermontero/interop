# =============================================================================
#  MDQR / DEVELOPMENT (apps stack)
#
#  Solo apps (mdqr-gateway, mdqr-decode-service).
#  Las tools (Consul/Redis/Vault/Keycloak) viven en deploy/tools/ — levantar
#  primero ese stack y luego este.
#
#  Las apps conectan a las tools via host.docker.internal (Linux: host-gateway).
#
#  Copiar como .env y descomentar lo que cambia.
# =============================================================================


# =============================================================================
#  1. COMUN
# =============================================================================
#MDQR_STACK_NAME=mdqr-dev
#MDQR_NETWORK_NAME=mdqr_net
#MDQR_NETWORK_MTU=1500

# Red externa compartida (misma que usan las tools). Crear ANTES de levantar:
#   docker network create --driver bridge mdqr_shared
#MDQR_SHARED_NETWORK=mdqr_shared

# Multi-tenancy. Vacio = single-tenant. Si se setea, suffix-a containers, service-names
# en Consul y crea subdir de logs por tenant.
#TENANT_ID=

# Spring profile activo por microservicio
#MDQR_GATEWAY_PROFILE=dev
#MDQR_DECRYPT_PROFILE=dev
#MDQR_ADMIN_PROFILE=dev


# =============================================================================
#  2. IMAGES + VERSIONS
# =============================================================================
#MDQR_GATEWAY_IMAGE=cr.sintesis.com.bo/mdqr-dev/mdqr-gateway
#MDQR_DECRYPT_IMAGE=cr.sintesis.com.bo/mdqr-dev/mdqr-decode-service
#MDQR_ADMIN_IMAGE=cr.sintesis.com.bo/mdqr-dev/mdqr-admin-service
#MDQR_GATEWAY_VERSION=latest
#MDQR_DECRYPT_VERSION=latest
#MDQR_ADMIN_VERSION=latest

# Frontends (registry distinto: mdqr-dev, sin guion). El gateway-URL
# va bakeado en el build de Angular (dev: http://localhost:8080), no en runtime.
#MDQR_ADMIN_FE_IMAGE=cr.sintesis.com.bo/mdqr-dev/mdqr-admin-fe
#MDQR_PUBLIC_FE_IMAGE=cr.sintesis.com.bo/mdqr-dev/mdqr-public-fe
#MDQR_ADMIN_FE_VERSION=latest
#MDQR_PUBLIC_FE_VERSION=latest


# =============================================================================
#  3. PORTS publicados al host
# =============================================================================
#MDQR_GATEWAY_PORT=0.0.0.0:8000
#MDQR_DECRYPT_PORT=127.0.0.1:8002
#MDQR_ADMIN_PORT=127.0.0.1:8001
# Frontends: nginx:80 publicado al host. Una sola var host:port (host opcional, default 0.0.0.0).
#MDQR_ADMIN_FE_PORT=0.0.0.0:3000
#MDQR_PUBLIC_FE_PORT=0.0.0.0:3001


# =============================================================================
#  4. TOOLS (apuntan a deploy/tools/ via host.docker.internal)
# =============================================================================
# Consul
#MDQR_CONSUL_HOST=host.docker.internal
#MDQR_CONSUL_PORT=8500
#MDQR_CONSUL_SCHEME=http
#MDQR_CONSUL_TOKEN=
#MDQR_CONSUL_CONFIG_ENABLED=false
#MDQR_DECRYPT_CONSUL_CONTEXT=config/decrypt-service

# Vault
#MDQR_VAULT_HOST=host.docker.internal
#MDQR_VAULT_PORT=8200
#MDQR_VAULT_SCHEME=http
# Para vault single (dev mode): TOKEN + root. Para cluster: APPROLE.
#MDQR_VAULT_AUTHENTICATION=TOKEN
#MDQR_VAULT_TOKEN=root
#MDQR_VAULT_ROLE_ID=
#MDQR_VAULT_SECRET_ID=

# Redis
#MDQR_REDIS_HOST=host.docker.internal
#MDQR_REDIS_PORT=6379
#MDQR_REDIS_PASSWORD=
# Redis cluster (stage). Vacio/false = single (dev). Formatos distintos:
#   MDQR_REDIS_NODES (Redisson/decrypt):   redis://h1:7001,redis://h2:7002,...
#   MDQR_REDIS_CLUSTER_NODES (SpringData): h1:7001,h2:7002,...
# true = Redis cluster (Spring Data); requiere MDQR_REDIS_CLUSTER_NODES.
#MDQR_REDIS_CLUSTER_ENABLED=false
#MDQR_REDIS_NODES=
#MDQR_REDIS_CLUSTER_NODES=

# Keycloak
# IMPORTANTE: el URL debe coincidir con el que keycloak embebe en el JWT iss.
# Tipicamente la IP LAN del host (no "host.docker.internal"), porque cuando un
# container hace POST a keycloak la respuesta del JWT toma el Host: header.
#MDQR_KEYCLOAK_URL=http://10.9.74.22:8080
# Realm base — se sufija con TENANT_ID en services/*.yml: mdqr[-<tenant>].
#MDQR_KEYCLOAK_REALM_BASE=mdqr
# external-url para validar el iss del JWT (resource-server). Por default = MDQR_KEYCLOAK_URL.
#MDQR_KEYCLOAK_EXTERNAL_URL=
# Frontend (admin-fe/public-fe) runtime config: URL+realm de Keycloak que el browser
# usa para el login OIDC. Debe ser alcanzable desde el navegador (no host.docker.internal).
#APP_KEYCLOAK_URL=http://localhost:8080
#APP_KEYCLOAK_REALM=mdqr
# Context-path de cada frontend (runtime, sin rebuild). '/' = raiz; '/mdqradmin/' = subpath.
#MDQR_ADMIN_FE_BASE_PATH=/
#MDQR_PUBLIC_FE_BASE_PATH=/
# Namespace base de Vault — se sufija con TENANT_ID: secret/mdqr[-<tenant>]/...
#MDQR_VAULT_NAMESPACE_BASE=mdqr
# KV mount del vault: 'secret' (dev) o 'kv' (stage, cluster monta kv/).
#MDQR_VAULT_KV_BACKEND=secret


# =============================================================================
#  5. DATABASES (PostgreSQL — externo o local; no esta en tools/)
# =============================================================================
#MDQR_DECRYPT_DB_URL=jdbc:postgresql://host.docker.internal:5432/mdqr
#MDQR_DECRYPT_DB_USER=postgres
#MDQR_DECRYPT_DB_PASSWORD=postgres
#MDQR_DECRYPT_LIQUIBASE_ENABLED=true

# admin-service (schema 'admin' dentro de la misma DB mdqr)
#MDQR_ADMIN_DB_URL=jdbc:postgresql://host.docker.internal:5432/mdqr
#MDQR_ADMIN_DB_USER=postgres
#MDQR_ADMIN_DB_PASSWORD=postgres


# =============================================================================
#  5b. ADMIN — secretos de servicio
#     En produccion estos viven en Vault; aqui defaults de dev overrideables.
# =============================================================================
# admin-service: service account para la Keycloak Admin API (gestion users/roles).
#MDQR_ADMIN_KC_CLIENT_ID=mdqr-admin-service
#MDQR_ADMIN_KC_CLIENT_SECRET=mdqr-admin-service-secret
#MDQR_ADMIN_KC_GRANT_TYPE=client_credentials

# Keycloak Event Listener webhook — shared secret enviado en X-Keycloak-Secret.
# Debe coincidir con el secret configurado en el realm event listener y en Vault
# (audit/keycloak-secret). Valor dev: se lee desde Vault; override aca solo si
# se omite Vault en desarrollo. Para produccion siempre usar Vault.
# NOTA: requiere el SPI provider keycloak-http-event-listener desplegado en Keycloak
# Setup: copiar el JAR provider a Keycloak providers/, reiniciar Keycloak,
# luego ejecutar keycloak-sync.sh con KC_AUDIT_WEBHOOK_ENABLED=true.
#MDQR_ADMIN_AUDIT_KC_SECRET=dev-keycloak-secret

# Audit: JWT client_credentials del service-account (header Authorization: Bearer).
# Los emisores (decrypt) reusan el client mdqr-api y piden el scope audit:write.
# El admin (receptor) lo valida como resource server. decrypt apunta via AUDIT_ENDPOINT.
# El endpoint apunta SIEMPRE al gateway (path /services/mdqradminservice/...) para ir con
# balanceo y validacion de Bearer, nunca directo al admin-service.
#MDQR_AUDIT_SCOPE=audit:write
#MDQR_AUDIT_ENDPOINT=http://mdqr-gateway:8080/services/mdqradminservice/admin/audit


# =============================================================================
#  6. CORS (gateway)
# =============================================================================
#MDQR_GATEWAY_CORS_ALLOWED_ORIGINS=*
#MDQR_GATEWAY_CORS_ALLOWED_METHODS=*
#MDQR_GATEWAY_CORS_ALLOWED_HEADERS=*
#MDQR_GATEWAY_CORS_ALLOW_CREDENTIALS=true


# =============================================================================
#  7. LOGGING
# =============================================================================
#LOG_DIR=~/logs/mdqr
#MDQR_LOG_MAX_FILE_SIZE=500MB
#MDQR_LOG_MAX_HISTORY=90
# Package level (bo.com.sintesis.ulqr.*)
#MDQR_GATEWAY_LOG_LEVEL=INFO
#MDQR_DECRYPT_LOG_LEVEL=INFO
#MDQR_ADMIN_LOG_LEVEL=INFO
# Root level (logging.level.root)
#MDQR_GATEWAY_ROOT_LOG_LEVEL=INFO
#MDQR_DECRYPT_ROOT_LOG_LEVEL=INFO
#MDQR_ADMIN_ROOT_LOG_LEVEL=INFO

# Hibernate SQL spam — subir a DEBUG cuando hace falta inspeccionar queries.
#MDQR_DECRYPT_LOG_LEVEL_HIBERNATE_SQL=WARN
#MDQR_DECRYPT_LOG_LEVEL_HIBERNATE_BIND=WARN


# =============================================================================
#  8. RESOURCE LIMITS
# =============================================================================
#MDQR_GATEWAY_MEM_LIMIT=768M
#MDQR_GATEWAY_MEM_RESERVATION=384M

#MDQR_DECRYPT_MEM_LIMIT=1024M
#MDQR_DECRYPT_MEM_RESERVATION=512M

#MDQR_ADMIN_MEM_LIMIT=1024M
#MDQR_ADMIN_MEM_RESERVATION=512M

#MDQR_ADMIN_FE_MEM_LIMIT=128M
#MDQR_PUBLIC_FE_MEM_LIMIT=128M


# =============================================================================
#  9. JVM opts (override per servicio)
# =============================================================================
#MDQR_GATEWAY_JAVA_OPTS=
#MDQR_DECRYPT_JAVA_OPTS=
#MDQR_ADMIN_JAVA_OPTS=


# =============================================================================
#  10. HEALTHCHECKS
# =============================================================================
#MDQR_HC_API_INTERVAL=30s
#MDQR_HC_API_TIMEOUT=10s
#MDQR_HC_API_RETRIES=3
#MDQR_HC_API_START_PERIOD=60s

# Frontends (nginx)
#MDQR_HC_WEB_INTERVAL=30s
#MDQR_HC_WEB_TIMEOUT=5s
#MDQR_HC_WEB_RETRIES=3
#MDQR_HC_WEB_START_PERIOD=10s
