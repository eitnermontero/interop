# =============================================================================
#  HUB / DEVELOPMENT (apps stack)
#
#  Solo apps (hub-gateway, hub-base-service).
#  Las tools (Consul/Redis/Vault/Keycloak) viven en deploy/tools/ — levantar
#  primero ese stack y luego este.
#
#  Las apps conectan a las tools via host.docker.internal (Linux: host-gateway).
#
#  Copiar como .env y descomentar lo que cambia.
# =============================================================================


# =============================================================================
#  1. COMUN
# =============================================================================
#HUB_STACK_NAME=hub-dev
#HUB_NETWORK_NAME=hub_net
#HUB_NETWORK_MTU=1500

# Red externa compartida (misma que usan las tools). Crear ANTES de levantar:
#   docker network create --driver bridge hub_shared
#HUB_SHARED_NETWORK=hub_shared

# Multi-tenancy. Vacio = single-tenant. Si se setea, suffix-a containers, service-names
# en Consul y crea subdir de logs por tenant.
#TENANT_ID=

# Spring profile activo por microservicio
#HUB_GATEWAY_PROFILE=dev
#HUB_BASE_PROFILE=dev
#HUB_ADMIN_PROFILE=dev


# =============================================================================
#  2. IMAGES + VERSIONS
# =============================================================================
#HUB_GATEWAY_IMAGE=cr.sintesis.com.bo/hub-dev/hub-gateway
#HUB_BASE_IMAGE=cr.sintesis.com.bo/hub-dev/hub-base-service
#HUB_ADMIN_IMAGE=cr.sintesis.com.bo/hub-dev/hub-admin-service
#HUB_GATEWAY_VERSION=latest
#HUB_BASE_VERSION=latest
#HUB_ADMIN_VERSION=latest

# Frontends (registry distinto: hub-dev, sin guion). El gateway-URL
# va bakeado en el build de Angular (dev: http://localhost:8080), no en runtime.
#HUB_ADMIN_FE_IMAGE=cr.sintesis.com.bo/hub-dev/hub-admin-fe
#HUB_PUBLIC_FE_IMAGE=cr.sintesis.com.bo/hub-dev/hub-public-fe
#HUB_ADMIN_FE_VERSION=latest
#HUB_PUBLIC_FE_VERSION=latest


# =============================================================================
#  3. PORTS publicados al host
# =============================================================================
#HUB_GATEWAY_PORT=0.0.0.0:8000
#HUB_BASE_PORT=127.0.0.1:8002
#HUB_ADMIN_PORT=127.0.0.1:8001
# Frontends: nginx:80 publicado al host. Una sola var host:port (host opcional, default 0.0.0.0).
#HUB_ADMIN_FE_PORT=0.0.0.0:3000
#HUB_PUBLIC_FE_PORT=0.0.0.0:3001


# =============================================================================
#  4. TOOLS (apuntan a deploy/tools/ via host.docker.internal)
# =============================================================================
# Consul
#HUB_CONSUL_HOST=host.docker.internal
#HUB_CONSUL_PORT=8500
#HUB_CONSUL_SCHEME=http
#HUB_CONSUL_TOKEN=
#HUB_CONSUL_CONFIG_ENABLED=false
#HUB_BASE_CONSUL_CONTEXT=config/base-service

# Vault
#HUB_VAULT_HOST=host.docker.internal
#HUB_VAULT_PORT=8200
#HUB_VAULT_SCHEME=http
# Para vault single (dev mode): TOKEN + root. Para cluster: APPROLE.
#HUB_VAULT_AUTHENTICATION=TOKEN
#HUB_VAULT_TOKEN=root
#HUB_VAULT_ROLE_ID=
#HUB_VAULT_SECRET_ID=

# Redis
#HUB_REDIS_HOST=host.docker.internal
#HUB_REDIS_PORT=6379
#HUB_REDIS_PASSWORD=
# Redis cluster (stage). Vacio/false = single (dev). Formatos distintos:
#   HUB_REDIS_NODES (Redisson/base-service):   redis://h1:7001,redis://h2:7002,...
#   HUB_REDIS_CLUSTER_NODES (SpringData): h1:7001,h2:7002,...
# true = Redis cluster (Spring Data); requiere HUB_REDIS_CLUSTER_NODES.
#HUB_REDIS_CLUSTER_ENABLED=false
#HUB_REDIS_NODES=
#HUB_REDIS_CLUSTER_NODES=

# Keycloak
# IMPORTANTE: el URL debe coincidir con el que keycloak embebe en el JWT iss.
# Tipicamente la IP LAN del host (no "host.docker.internal"), porque cuando un
# container hace POST a keycloak la respuesta del JWT toma el Host: header.
#HUB_KEYCLOAK_URL=http://10.9.74.22:8080
# Realm base — se sufija con TENANT_ID en services/*.yml: hub[-<tenant>].
#HUB_KEYCLOAK_REALM_BASE=hub
# external-url para validar el iss del JWT (resource-server). Por default = HUB_KEYCLOAK_URL.
#HUB_KEYCLOAK_EXTERNAL_URL=
# Frontend (admin-fe/public-fe) runtime config: URL+realm de Keycloak que el browser
# usa para el login OIDC. Debe ser alcanzable desde el navegador (no host.docker.internal).
#APP_KEYCLOAK_URL=http://localhost:8080
#APP_KEYCLOAK_REALM=hub
# Context-path de cada frontend (runtime, sin rebuild). '/' = raiz; '/hubadmin/' = subpath.
#HUB_ADMIN_FE_BASE_PATH=/
#HUB_PUBLIC_FE_BASE_PATH=/
# Namespace base de Vault — se sufija con TENANT_ID: secret/hub[-<tenant>]/...
#HUB_VAULT_NAMESPACE_BASE=hub
# KV mount del vault: 'secret' (dev) o 'kv' (stage, cluster monta kv/).
#HUB_VAULT_KV_BACKEND=secret


# =============================================================================
#  5. DATABASES (PostgreSQL — externo o local; no esta en tools/)
# =============================================================================
#HUB_BASE_DB_URL=jdbc:postgresql://host.docker.internal:5432/hub
#HUB_BASE_DB_USER=postgres
#HUB_BASE_DB_PASSWORD=postgres
#HUB_BASE_LIQUIBASE_ENABLED=true

# admin-service (schema 'admin' dentro de la misma DB hub)
#HUB_ADMIN_DB_URL=jdbc:postgresql://host.docker.internal:5432/hub
#HUB_ADMIN_DB_USER=postgres
#HUB_ADMIN_DB_PASSWORD=postgres


# =============================================================================
#  5b. ADMIN — secretos de servicio
#     En produccion estos viven en Vault; aqui defaults de dev overrideables.
# =============================================================================
# admin-service: service account para la Keycloak Admin API (gestion users/roles).
#HUB_ADMIN_KC_CLIENT_ID=hub-admin-service
#HUB_ADMIN_KC_CLIENT_SECRET=hub-admin-service-secret
#HUB_ADMIN_KC_GRANT_TYPE=client_credentials

# Keycloak Event Listener webhook — shared secret enviado en X-Keycloak-Secret.
# Debe coincidir con el secret configurado en el realm event listener y en Vault
# (audit/keycloak-secret). Valor dev: se lee desde Vault; override aca solo si
# se omite Vault en desarrollo. Para produccion siempre usar Vault.
# NOTA: requiere el SPI provider keycloak-http-event-listener desplegado en Keycloak
# Setup: copiar el JAR provider a Keycloak providers/, reiniciar Keycloak,
# luego ejecutar keycloak-sync.sh con KC_AUDIT_WEBHOOK_ENABLED=true.
#HUB_ADMIN_AUDIT_KC_SECRET=dev-keycloak-secret

# Audit: JWT client_credentials del service-account (header Authorization: Bearer).
# Los emisores (base-service) reusan el client hub-api y piden el scope audit:write.
# El admin (receptor) lo valida como resource server. base-service apunta via AUDIT_ENDPOINT.
# El endpoint apunta SIEMPRE al gateway (path /services/hubadminservice/...) para ir con
# balanceo y validacion de Bearer, nunca directo al admin-service.
#HUB_AUDIT_SCOPE=audit:write
#HUB_AUDIT_ENDPOINT=http://hub-gateway:8080/services/hubadminservice/admin/audit


# =============================================================================
#  6. CORS (gateway)
# =============================================================================
#HUB_GATEWAY_CORS_ALLOWED_ORIGINS=*
#HUB_GATEWAY_CORS_ALLOWED_METHODS=*
#HUB_GATEWAY_CORS_ALLOWED_HEADERS=*
#HUB_GATEWAY_CORS_ALLOW_CREDENTIALS=true


# =============================================================================
#  7. LOGGING
# =============================================================================
#LOG_DIR=~/logs/hub
#HUB_LOG_MAX_FILE_SIZE=500MB
#HUB_LOG_MAX_HISTORY=90
# Package level (bo.com.sintesis.hub.*)
#HUB_GATEWAY_LOG_LEVEL=INFO
#HUB_BASE_LOG_LEVEL=INFO
#HUB_ADMIN_LOG_LEVEL=INFO
# Root level (logging.level.root)
#HUB_GATEWAY_ROOT_LOG_LEVEL=INFO
#HUB_BASE_ROOT_LOG_LEVEL=INFO
#HUB_ADMIN_ROOT_LOG_LEVEL=INFO

# Hibernate SQL spam — subir a DEBUG cuando hace falta inspeccionar queries.
#HUB_BASE_LOG_LEVEL_HIBERNATE_SQL=WARN
#HUB_BASE_LOG_LEVEL_HIBERNATE_BIND=WARN


# =============================================================================
#  8. RESOURCE LIMITS
# =============================================================================
#HUB_GATEWAY_MEM_LIMIT=768M
#HUB_GATEWAY_MEM_RESERVATION=384M

#HUB_BASE_MEM_LIMIT=1024M
#HUB_BASE_MEM_RESERVATION=512M

#HUB_ADMIN_MEM_LIMIT=1024M
#HUB_ADMIN_MEM_RESERVATION=512M

#HUB_ADMIN_FE_MEM_LIMIT=128M
#HUB_PUBLIC_FE_MEM_LIMIT=128M


# =============================================================================
#  9. JVM opts (override per servicio)
# =============================================================================
#HUB_GATEWAY_JAVA_OPTS=
#HUB_BASE_JAVA_OPTS=
#HUB_ADMIN_JAVA_OPTS=


# =============================================================================
#  10. HEALTHCHECKS
# =============================================================================
#HUB_HC_API_INTERVAL=30s
#HUB_HC_API_TIMEOUT=10s
#HUB_HC_API_RETRIES=3
#HUB_HC_API_START_PERIOD=60s

# Frontends (nginx)
#HUB_HC_WEB_INTERVAL=30s
#HUB_HC_WEB_TIMEOUT=5s
#HUB_HC_WEB_RETRIES=3
#HUB_HC_WEB_START_PERIOD=10s
