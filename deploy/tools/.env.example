# =============================================================================
#  MDQR / TOOLS (Consul, Redis, Vault, Keycloak)
#
#  Stack aislado de los stacks de aplicacion. Las apps (mdqr-gateway,
#  mdqr-decode-service, etc.) conectan aca via IP del host.
#
#  Modos (toggle via COMPOSE_PROFILES):
#    - single (default): 1 redis + 1 consul + 1 vault (dev) + keycloak
#    - cluster:          3 consul + 6 redis + 3 vault (raft HA) + keycloak
#
#  Copiar como .env y descomentar lo que cambia.
# =============================================================================


# =============================================================================
#  1. COMPOSE_PROFILES — selecciona modo single o cluster
# =============================================================================
# Default: single-node (suficiente para dev/QA/prod-like rapido)
COMPOSE_PROFILES=single

# Para simular prod con HA real (validar failover, slot rebalance, raft):
#COMPOSE_PROFILES=cluster

# IMPORTANTE en cluster mode: tras `up -d` ejecutar UNA vez:
#   ./scripts/redis-cluster-init.sh
#   ./scripts/vault-cluster-init.sh


# =============================================================================
#  2. COMUN
# =============================================================================
#MDQR_TOOLS_STACK_NAME=mdqr-tools
#MDQR_TOOLS_NETWORK_NAME=mdqr-tools-net

# Red externa compartida — linkea las tools con apps de otros stacks via DNS interno.
# Crear ANTES de levantar el stack:
#   docker network create --driver bridge --opt com.docker.network.driver.mtu=1500 mdqr_shared
#MDQR_SHARED_NETWORK=mdqr_shared

# Bind IP de los puertos publicados. 127.0.0.1 = solo localhost. 0.0.0.0 = LAN
# (necesario si las apps viven en otra red Docker y conectan via IP del host).
#MDQR_TOOLS_BIND_IP=0.0.0.0

# IP del host (REQUIRED para cluster mode: Redis cluster-announce-ip y Vault api_addr).
# Las apps tambien lo usan en lugar de "consul"/"redis"/"vault" hostnames.
#MDQR_HOST_IP=192.168.0.12


# =============================================================================
#  3. CONSUL  (defaults: puertos oficiales del producto)
# =============================================================================
#MDQR_CONSUL_IMAGE=hashicorp/consul:1.22
#MDQR_CONSUL_LOG_LEVEL=INFO
#MDQR_CONSUL_DATACENTER=dc-mdqr-prod

# Single-node:
#MDQR_CONSUL_HTTP_PORT=8500
#MDQR_CONSUL_RPC_PORT=8300
#MDQR_CONSUL_DNS_PORT=8600

# Cluster (3 nodes):
#MDQR_CONSUL_S1_HTTP_PORT=8500
#MDQR_CONSUL_S2_HTTP_PORT=8501
#MDQR_CONSUL_S3_HTTP_PORT=8502


# =============================================================================
#  4. REDIS  (defaults: puerto oficial 6379)
# =============================================================================
#MDQR_REDIS_IMAGE=redis:8.8

# Single-node:
#MDQR_REDIS_PORT=6379
#MDQR_REDIS_APPENDONLY=yes

# Cluster (6 nodes — 3 master + 3 replica). Puertos contiguos 6379-6384.
#MDQR_REDIS_M1_PORT=6379
#MDQR_REDIS_M2_PORT=6380
#MDQR_REDIS_M3_PORT=6381
#MDQR_REDIS_R1_PORT=6382
#MDQR_REDIS_R2_PORT=6383
#MDQR_REDIS_R3_PORT=6384
# Bus ports (gossip, +10000 al puerto cliente):
#MDQR_REDIS_M1_BUS_PORT=16379
#MDQR_REDIS_M2_BUS_PORT=16380
#MDQR_REDIS_M3_BUS_PORT=16381
#MDQR_REDIS_R1_BUS_PORT=16382
#MDQR_REDIS_R2_BUS_PORT=16383
#MDQR_REDIS_R3_BUS_PORT=16384
#MDQR_REDIS_CLUSTER_NODE_TIMEOUT_MS=10000


# =============================================================================
#  5. VAULT
# =============================================================================
#MDQR_VAULT_IMAGE=hashicorp/vault:1.21

# Single-node (dev mode): unsealed, root token preseteado. NO usar en prod.
#MDQR_VAULT_PORT=8200
#MDQR_VAULT_DEV_ROOT_TOKEN=root

# Cluster (3 nodes raft HA). Requiere init+unseal: ./scripts/vault-cluster-init.sh
# API ports (cliente) y cluster ports (raft replication):
#MDQR_VAULT_1_PORT=8200
#MDQR_VAULT_1_CLUSTER_PORT=8201
#MDQR_VAULT_2_PORT=8210
#MDQR_VAULT_2_CLUSTER_PORT=8211
#MDQR_VAULT_3_PORT=8220
#MDQR_VAULT_3_CLUSTER_PORT=8221


# =============================================================================
#  6. KEYCLOAK  (defaults: puertos oficiales 8080/8443)
# =============================================================================
#KEYCLOAK_IMAGE=quay.io/keycloak/keycloak:26.6

# Puerto publicado al host. IMPORTANTE: en el servidor el gateway ocupa 8080,
# usar 8180 para Keycloak (o el puerto que elijas, debe ser consistente con
# MDQR_KEYCLOAK_URL en deploy/production/.env).
KEYCLOAK_HTTP_PORT=8180
#KEYCLOAK_HTTPS_PORT=8443
#KEYCLOAK_INTERNAL_HTTP_PORT=8080
#KEYCLOAK_INTERNAL_HTTPS_PORT=8443
#KEYCLOAK_MANAGEMENT_PORT=9990

KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=<KEYCLOAK_ADMIN_PASSWORD>
#KEYCLOAK_FEATURES=scripts
#KEYCLOAK_HEALTH_ENABLED=true

# ---------------------------------------------------------------------------
#  Keycloak en DEV (default): storage en memoria, pierde datos al reiniciar.
# ---------------------------------------------------------------------------
#KEYCLOAK_COMMAND=start-dev
#KEYCLOAK_DB=dev-file

# ---------------------------------------------------------------------------
#  Keycloak en PRODUCCIÓN: PostgreSQL como backend de datos.
#  Crear la DB antes: CREATE DATABASE mdqr_keycloak;
#  El comando 'start' (no start-dev) requiere HTTPS o KC_HOSTNAME configurado.
# ---------------------------------------------------------------------------
KEYCLOAK_COMMAND=start-dev
# Para producción, descomentar y rellenar:
#KEYCLOAK_COMMAND=start
#KEYCLOAK_DB=postgres
#KEYCLOAK_DB_URL=jdbc:postgresql://host.docker.internal:5432/mdqr_keycloak
#KEYCLOAK_DB_USERNAME=keycloak
#KEYCLOAK_DB_PASSWORD=<KEYCLOAK_DB_PASSWORD>
# Hostname público (el que el browser ve, igual que MDQR_KEYCLOAK_URL sin /):
#KEYCLOAK_HOSTNAME=<SERVER_IP_OR_HOSTNAME>:8180
#KEYCLOAK_HOSTNAME_STRICT=false
# Si hay reverse proxy/nginx delante de Keycloak que termina TLS:
#KEYCLOAK_PROXY_HEADERS=xforwarded
#KEYCLOAK_HTTP_ENABLED=true


# =============================================================================
#  7. RESOURCE LIMITS (deploy.resources.limits/reservations)
# =============================================================================
# Defaults razonables para QA/dev. Subir en cluster mode si necesitas mas headroom.

# Consul (single y cluster — cada nodo del cluster también consume esto)
#MDQR_CONSUL_MEM_LIMIT=256M
#MDQR_CONSUL_CPU_LIMIT=0.5
#MDQR_CONSUL_MEM_RESERVATION=128M
#MDQR_CONSUL_CPU_RESERVATION=0.1

# Redis (single y cada nodo del cluster)
#MDQR_REDIS_MEM_LIMIT=256M
#MDQR_REDIS_CPU_LIMIT=0.5
#MDQR_REDIS_MEM_RESERVATION=64M
#MDQR_REDIS_CPU_RESERVATION=0.1

# Vault (single y cada nodo del raft cluster)
#MDQR_VAULT_MEM_LIMIT=256M
#MDQR_VAULT_CPU_LIMIT=0.5
#MDQR_VAULT_MEM_RESERVATION=64M
#MDQR_VAULT_CPU_RESERVATION=0.1

# Keycloak (mas RAM porque es JVM Quarkus + Infinispan)
#MDQR_KEYCLOAK_MEM_LIMIT=768M
#MDQR_KEYCLOAK_CPU_LIMIT=1.0
#MDQR_KEYCLOAK_MEM_RESERVATION=384M
#MDQR_KEYCLOAK_CPU_RESERVATION=0.25

# =============================================================================
#  8. HEALTHCHECKS
# =============================================================================
#MDQR_HC_CONSUL_INTERVAL=10s
#MDQR_HC_CONSUL_TIMEOUT=5s
#MDQR_HC_CONSUL_RETRIES=12
#MDQR_HC_REDIS_INTERVAL=10s
#MDQR_HC_REDIS_TIMEOUT=5s
#MDQR_HC_REDIS_RETRIES=12
#MDQR_HC_VAULT_INTERVAL=10s
#MDQR_HC_VAULT_TIMEOUT=5s
#MDQR_HC_VAULT_RETRIES=12
